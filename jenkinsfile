pipeline {
    agent any

    triggers {
        cron('H/10 * * * *')
    }

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
                bat 'npx playwright install chromium'
            }
        }

        stage('Run Playwright Test') {
            steps {
                bat 'npx playwright test --project=chromium'
            }
        }

        stage('Show Report') {
            steps {
                bat 'npx playwright show-report'
            }
        }
    }
}